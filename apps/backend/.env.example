NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doctemplate?schema=public
PUBLIC_BASE_URL=http://localhost:3001

# Auth
JWT_SECRET=change-me-generate-at-least-32-characters-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# CORS — comma-separated frontend origins
CORS_ORIGINS=http://localhost:3000

# Webhook signing
WEBHOOK_SIGNING_SECRET=change-me-generate-another-long-random-string

# Workers
GENERATION_WORKER_INTERVAL_MS=1000
WEBHOOK_WORKER_INTERVAL_MS=2000
WEBHOOK_REQUEST_TIMEOUT_MS=10000

# Uploads
MAX_UPLOAD_SIZE_BYTES=26214400

# Storage
STORAGE_DRIVER=local
STORAGE_ROOT=./storage

# S3 (only when STORAGE_DRIVER=s3)
# S3_BUCKET=doctemplate-prod
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=  # e.g. https://minio.local:9000 for MinIO / LocalStack

# Puppeteer — optional override if system Chrome is preferred
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
