# Keep Docker build context lean. Anything matching here is excluded from
# `dockerContext: .` in render.yaml so node_modules / .next / local storage
# don't bloat the image or leak secrets.
**/node_modules
**/dist
**/.next
**/.turbo
**/.cache

# Local-only state — never bake into the image
**/.env
**/.env.local
**/.env.*.local
# Anchor storage/ to runtime locations so the src/storage source module
# (diskStorage, fileStorage, s3Storage) isn't excluded from the build context.
/storage
/apps/backend/storage

# VCS + tooling
.git
.github
*.log
.DS_Store

# Frontend workspace isn't needed in the backend image
apps/frontend
